{
  "id": "five-secret-codes",
  "name": "5 Secret [Tool] Codes",
  "niche": "any tool with power-user tricks",
  "description": "Listicle: hook announces 5 secret codes for a tool (title card + preview flip-through), five code blocks each opened by a spoken ordinal marker ('First is [name]') that captures the user's own name for the code onto a title card, with concurrent screen recordings and meme punchlines timed to the explanation's clauses, then a comment-keyword CTA. Literal anchors mark the block structure; semantic anchors, windowed by them, time the content moments.",
  "fps": 30,
  "width": 1080,
  "height": 1920,
  "captionStyle": {
    "component": "Captions",
    "params": {
      "position": "lowerThird"
    }
  },
  "musicSlot": {
    "name": "music",
    "mediaType": "audio",
    "required": false,
    "instructions": "Optional music bed you own or that is licensed to you. For posting, prefer adding trending audio inside Instagram/TikTok."
  },
  "musicVolume": 0.35,
  "sharedSlots": [
    {
      "name": "bell_sfx",
      "mediaType": "audio",
      "required": false,
      "instructions": "A short bell 'ding' (CC0 or owned). Rings on every code's title card and at the end of the hook."
    },
    {
      "name": "click_sfx",
      "mediaType": "audio",
      "required": false,
      "instructions": "A short UI click. Fires on each hook preview image, each result screenshot, and the CTA keyword."
    },
    {
      "name": "typing_sfx",
      "mediaType": "audio",
      "required": false,
      "instructions": "A keyboard-typing loop, a few seconds long. Plays under the screen recordings (it gets cut to fit)."
    },
    {
      "name": "punchline_sfx",
      "mediaType": "audio",
      "required": false,
      "instructions": "A comedic hit/boom for meme punchlines."
    },
    {
      "name": "shutter_sfx",
      "mediaType": "audio",
      "required": false,
      "instructions": "A camera-shutter snap for the hook title card."
    },
    {
      "name": "reaction_sfx",
      "mediaType": "audio",
      "required": false,
      "instructions": "A surprised-reaction sound (gasp, record scratch...) for reaction memes."
    },
    {
      "name": "reaction2_sfx",
      "mediaType": "audio",
      "required": false,
      "instructions": "A second, different reaction sound so back-to-back reactions in the final code don't repeat."
    },
    {
      "name": "positive_sfx",
      "mediaType": "audio",
      "required": false,
      "instructions": "A positive chime/'yay' for the positive-reaction meme."
    }
  ],
