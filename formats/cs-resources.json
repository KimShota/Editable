      "kind": "broll",
      "videoSlot": "resource3_clip",
      "brollDurationSec": 1.6,
      "slots": [
        {
          "name": "resource3_clip",
          "mediaType": "video",
          "instructions": "Screen recording of the third resource — scroll its page slowly. 2–3 seconds is plenty."
        },
        {
          "name": "resource3_title",
          "mediaType": "text",
          "instructions": "The resource's name, short."
        },
        {
          "name": "resource3_desc",
          "mediaType": "text",
